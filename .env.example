# Amplified-on-Solana dashboard

# Solana RPC endpoint. Public RPC works but is rate-limited; Helius/QuickNode
# recommended for backfill.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Writable path for the SQLite cache. Mount this on a persistent volume in
# production so the backfill survives container restarts.
AMP_DB_PATH=./data/amp.db

# ISO 8601 launch timestamp. Any tx before this is ignored (pre-launch activity
# is typically internal payments / testing, not real trading flow).
AMP_LAUNCH_TS=2026-04-01T18:23:00Z

# Comma-separated Solana addresses to exclude from "user payouts" accounting.
# Set this once you know which wallets are dev/team.
AMP_OPERATOR_WALLETS=

# Optional: address of the pool / refund wallet (outflows here are overliquidation
# refunds or gas refunds, not the weekly 50% user share).
AMP_POOL_WALLET=

# Amplified SPL token mint. When set, the indexer fetches the token's total
# supply once via getTokenSupply and caches it in SQLite. Used by the in-page
# revenue calculator to translate "your tokens" into a share-of-supply.
AMP_TOKEN_MINT=

# Fallback supply if AMP_TOKEN_MINT is not set or the fetch hasn't completed.
AMP_TOTAL_SUPPLY=1000000000
